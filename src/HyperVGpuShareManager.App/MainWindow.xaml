<Window x:Class="HyperVGpuShareManager.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hyper-V GPU Share Manager"
        Width="1360"
        Height="880"
        MinWidth="1120"
        MinHeight="760"
        WindowStartupLocation="CenterScreen">
  <Window.Resources>
    <Style TargetType="ListBoxItem">
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="Margin" Value="0,0,0,8" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ListBoxItem">
            <Border Background="{TemplateBinding Background}" CornerRadius="8">
              <ContentPresenter />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource PanelAltBrush}" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Grid Background="{DynamicResource WindowBrush}">
    <Grid.RowDefinitions>
      <RowDefinition Height="76" />
      <RowDefinition Height="*" />
      <RowDefinition Height="30" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="24,14">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <StackPanel>
          <TextBlock Text="Hyper-V GPU Share Manager" FontSize="24" FontWeight="SemiBold" />
          <TextBlock Text="GPU Partitioning / GPU-P para compartir una GPU fisica entre host y VM" Style="{StaticResource CaptionStyle}" />
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
          <Button Content="{Binding ThemeLabel}" Command="{Binding ToggleThemeCommand}" />
          <Button Content="Actualizar" Command="{Binding RefreshCommand}" />
          <Button Content="Exportar diagnostico" Command="{Binding ExportDiagnosticsCommand}" />
        </StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Row="1" Margin="20">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="235" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="360" />
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,14,0">
        <StackPanel>
          <TextBlock Text="Asistente" Style="{StaticResource SectionTitleStyle}" />
          <ItemsControl ItemsSource="{Binding Steps}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Button Command="{Binding DataContext.SelectStepCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="{Binding}"
                        Padding="12"
                        Margin="0,0,0,8"
                        HorizontalContentAlignment="Stretch">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="34" />
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="18" />
                    </Grid.ColumnDefinitions>
                    <Border Width="26" Height="26" CornerRadius="13" Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                      <TextBlock Text="{Binding Number}" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold" />
                    </Border>
                    <TextBlock Grid.Column="1" Text="{Binding Title}" VerticalAlignment="Center" FontWeight="SemiBold" />
                    <Ellipse Grid.Column="2"
                             Width="10"
                             Height="10"
                             VerticalAlignment="Center"
                             Fill="{Binding IsComplete, Converter={StaticResource BooleanBrushConverter}}" />
                  </Grid>
                </Button>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <Separator Margin="0,8,0,14" Background="{DynamicResource BorderBrush}" />
          <TextBlock Text="Estado actual" FontWeight="SemiBold" Margin="0,0,0,8" />
          <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource MutedTextBrush}" />
          <ProgressBar Height="6"
                       Margin="0,14,0,0"
                       IsIndeterminate="True"
                       Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" />
        </StackPanel>
      </Border>

      <TabControl Grid.Column="1"
                  SelectedIndex="{Binding SelectedStepIndex}"
                  Background="Transparent"
                  BorderThickness="0">
        <TabControl.Resources>
          <Style TargetType="TabItem">
            <Setter Property="Visibility" Value="Collapsed" />
          </Style>
        </TabControl.Resources>

        <TabItem>
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,14,0">
              <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                  <TextBlock Text="Paso 1: Comprobar sistema" Style="{StaticResource SectionTitleStyle}" />
                  <UniformGrid Columns="2" Rows="2">
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,10,10">
                      <StackPanel>
                        <TextBlock Text="Windows" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding SystemStatus.WindowsCaption, TargetNullValue='No detectado'}" Foreground="{DynamicResource MutedTextBrush}" />
                        <TextBlock Text="{Binding SystemStatus.WindowsVersion, TargetNullValue='No detectado'}" Foreground="{DynamicResource MutedTextBrush}" />
                      </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                      <StackPanel>
                        <TextBlock Text="Hyper-V" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding SystemStatus.IsHyperVEnabled, Converter={StaticResource BooleanStatusConverter}, ConverterParameter=Habilitado|No habilitado}"
                                   Foreground="{Binding SystemStatus.IsHyperVEnabled, Converter={StaticResource BooleanBrushConverter}}" />
                        <TextBlock Text="{Binding HyperVCmdletsAvailable, Converter={StaticResource BooleanStatusConverter}, ConverterParameter=Cmdlets disponibles|Cmdlets incompletos}"
                                   Foreground="{Binding HyperVCmdletsAvailable, Converter={StaticResource BooleanBrushConverter}}" />
                      </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,10,0">
                      <StackPanel>
                        <TextBlock Text="Administrador" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding SystemStatus.IsAdministrator, Converter={StaticResource BooleanStatusConverter}, ConverterParameter=Elevado|No elevado}"
                                   Foreground="{Binding SystemStatus.IsAdministrator, Converter={StaticResource BooleanBrushConverter}}" />
                      </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardStyle}" Margin="0">
                      <StackPanel>
                        <TextBlock Text="Virtualizacion" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding SystemStatus.VirtualizationFirmwareEnabled, Converter={StaticResource BooleanStatusConverter}, ConverterParameter=Detectada|Revisar BIOS/UEFI}"
                                   Foreground="{Binding SystemStatus.VirtualizationFirmwareEnabled, Converter={StaticResource BooleanBrushConverter}}" />
                      </StackPanel>
                    </Border>
                  </UniformGrid>
                </StackPanel>
              </Border>

              <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                  <TextBlock Text="Advertencias y comprobaciones" Style="{StaticResource SectionTitleStyle}" />
                  <ItemsControl ItemsSource="{Binding ValidationResults}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                          <StackPanel>
                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" Foreground="{Binding Severity, Converter={StaticResource SeverityBrushConverter}}" />
                            <TextBlock Text="{Binding Message}" Foreground="{DynamicResource MutedTextBrush}" />
                          </StackPanel>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </Border>
            </StackPanel>
          </ScrollViewer>
        </TabItem>

        <TabItem>
          <Grid Margin="0,0,14,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,14,0">
              <StackPanel>
                <TextBlock Text="Paso 2: Seleccionar GPU" Style="{StaticResource SectionTitleStyle}" />
                <ListBox ItemsSource="{Binding Gpus}" SelectedItem="{Binding SelectedGpu}" Background="Transparent" BorderThickness="0">
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,8">
                        <Grid>
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                          </Grid.ColumnDefinitions>
                          <Border Background="{Binding Vendor, Converter={StaticResource VendorAccentBrushConverter}}" CornerRadius="4" />
                          <StackPanel Grid.Column="1" Margin="14,0,8,0">
                            <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding VendorLabel}" Foreground="{DynamicResource MutedTextBrush}" />
                            <TextBlock Text="{Binding DriverVersion, StringFormat={}Driver {0}}" Foreground="{DynamicResource MutedTextBrush}" />
                            <TextBlock Text="{Binding DeviceInstancePath}" Foreground="{DynamicResource MutedTextBrush}" FontSize="11" />
                            <TextBlock Text="{Binding Warning}" Foreground="{DynamicResource WarningBrush}" Visibility="{Binding Warning, Converter={StaticResource StringToVisibilityConverter}}" />
                          </StackPanel>
                          <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <TextBlock Text="{Binding IsPartitionable, Converter={StaticResource BooleanStatusConverter}, ConverterParameter=GPU-P OK|No GPU-P}"
                                       Foreground="{Binding IsPartitionable, Converter={StaticResource BooleanBrushConverter}}"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{Binding AdapterRamBytes, Converter={StaticResource BytesToDisplayConverter}}" Foreground="{DynamicResource MutedTextBrush}" HorizontalAlignment="Right" />
                          </StackPanel>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource CardStyle}">
              <StackPanel>
                <TextBlock Text="GPU seleccionada" Style="{StaticResource SectionTitleStyle}" />
                <Border Height="150"
                        CornerRadius="8"
                        Background="{Binding SelectedGpu.Vendor, Converter={StaticResource VendorAccentBrushConverter}}"
                        Visibility="{Binding SelectedGpu, Converter={StaticResource NullToVisibilityConverter}}">
                  <TextBlock Text="{Binding SelectedGpu.VendorLabel}"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             FontSize="30"
                             FontWeight="Bold"
                             Foreground="White"
                             TextAlignment="Center" />
                </Border>
                <TextBlock Text="{Binding SelectedGpu.Name}" FontWeight="SemiBold" Margin="0,12,0,4" />
                <TextBlock Text="{Binding SelectedGpu.PartitionableDetails}" Foreground="{DynamicResource MutedTextBrush}" FontSize="11" />
                <TextBlock Text="Si esta GPU no aparece como particionable, el driver o hardware pueden no soportar GPU Partitioning."
                           Foreground="{DynamicResource WarningBrush}"
                           Margin="0,12,0,0"
                           Visibility="{Binding SelectedGpu.IsPartitionable, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert}" />
              </StackPanel>
            </Border>
          </Grid>
        </TabItem>

        <TabItem>
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid Margin="0,0,14,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>

              <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,14,0">
                <StackPanel>
                  <TextBlock Text="Paso 3A: Usar VM existente" Style="{StaticResource SectionTitleStyle}" />
                  <ListBox ItemsSource="{Binding VirtualMachines}" SelectedItem="{Binding SelectedVm}" Background="Transparent" BorderThickness="0" MaxHeight="350">
                    <ListBox.ItemTemplate>
                      <DataTemplate>
                        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="12">
                          <Grid>
                            <Grid.ColumnDefinitions>
                              <ColumnDefinition Width="*" />
                              <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                              <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                              <TextBlock Text="{Binding Path}" Foreground="{DynamicResource MutedTextBrush}" FontSize="11" />
                              <TextBlock Text="{Binding HasGpuPartitionAdapter, Converter={StaticResource BooleanStatusConverter}, ConverterParameter=GPU-P configurado|Sin GPU-P}"
                                         Foreground="{Binding HasGpuPartitionAdapter, Converter={StaticResource BooleanBrushConverter}}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="12,0,0,0">
                              <TextBlock Text="{Binding State}" FontWeight="SemiBold" HorizontalAlignment="Right" />
                              <TextBlock Text="{Binding Generation, StringFormat={}Gen {0}}" Foreground="{DynamicResource MutedTextBrush}" HorizontalAlignment="Right" />
                              <TextBlock Text="{Binding ProcessorCount, StringFormat={}{0} CPU}" Foreground="{DynamicResource MutedTextBrush}" HorizontalAlignment="Right" />
                            </StackPanel>
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>

                  <WrapPanel Margin="0,12,0,0">
                    <CheckBox Content="Forzar apagado si es necesario" IsChecked="{Binding ForceTurnOff}" />
                    <Button Content="Apagar VM" Command="{Binding StopVmCommand}" />
                    <Button Content="Abrir VMConnect" Command="{Binding OpenVmConnectCommand}" />
                  </WrapPanel>
                </StackPanel>
              </Border>

              <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                <StackPanel>
                  <TextBlock Text="Paso 3B: Crear VM nueva" Style="{StaticResource SectionTitleStyle}" />
                  <TextBlock Text="Nombre de VM" Style="{StaticResource CaptionStyle}" />
                  <TextBox Text="{Binding NewVmRequest.Name, UpdateSourceTrigger=PropertyChanged}" />
                  <TextBlock Text="Ruta de almacenamiento" Style="{StaticResource CaptionStyle}" />
                  <DockPanel>
                    <Button DockPanel.Dock="Right" Content="..." Command="{Binding BrowseStorageCommand}" Width="42" />
                    <TextBox Text="{Binding NewVmRequest.StoragePath, UpdateSourceTrigger=PropertyChanged}" />
                  </DockPanel>
                  <TextBlock Text="ISO de Windows 10 Pro" Style="{StaticResource CaptionStyle}" />
                  <DockPanel>
                    <Button DockPanel.Dock="Right" Content="..." Command="{Binding BrowseIsoCommand}" Width="42" />
                    <TextBox Text="{Binding NewVmRequest.IsoPath, UpdateSourceTrigger=PropertyChanged}" />
                  </DockPanel>
                  <UniformGrid Columns="3">
                    <StackPanel Margin="0,0,8,0">
                      <TextBlock Text="RAM inicial MB" Style="{StaticResource CaptionStyle}" />
                      <TextBox Text="{Binding NewVmRequest.StartupMemoryMB}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,8,0">
                      <TextBlock Text="CPUs" Style="{StaticResource CaptionStyle}" />
                      <TextBox Text="{Binding NewVmRequest.ProcessorCount}" />
                    </StackPanel>
                    <StackPanel>
                      <TextBlock Text="VHDX GB" Style="{StaticResource CaptionStyle}" />
                      <TextBox Text="{Binding NewVmRequest.VhdSizeGB}" />
                    </StackPanel>
                  </UniformGrid>
                  <TextBlock Text="Switch virtual" Style="{StaticResource CaptionStyle}" />
                  <ComboBox ItemsSource="{Binding VirtualSwitches}"
                            DisplayMemberPath="Name"
                            SelectedValuePath="Name"
                            SelectedValue="{Binding NewVmRequest.SwitchName}" />
                  <TextBlock Text="Generacion" Style="{StaticResource CaptionStyle}" />
                  <TextBox Text="{Binding NewVmRequest.Generation}" />
                  <Button Content="Crear VM" Command="{Binding CreateVmCommand}" Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Left" />
                </StackPanel>
              </Border>
            </Grid>
          </ScrollViewer>
        </TabItem>

        <TabItem>
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Border Style="{StaticResource CardStyle}" Margin="0,0,14,0">
              <StackPanel>
                <TextBlock Text="Paso 4: Configurar recursos GPU" Style="{StaticResource SectionTitleStyle}" />
                <Button Content="Restaurar valores recomendados" Command="{Binding RestoreRecommendedCommand}" HorizontalAlignment="Left" />
                <Grid Margin="0,12,0,0">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                  </Grid.RowDefinitions>
                  <TextBlock Grid.Column="1" Text="Min" Style="{StaticResource CaptionStyle}" />
                  <TextBlock Grid.Column="2" Text="Optimal" Style="{StaticResource CaptionStyle}" />
                  <TextBlock Grid.Column="3" Text="Max" Style="{StaticResource CaptionStyle}" />

                  <TextBlock Grid.Row="1" Text="VRAM bytes" VerticalAlignment="Center" FontWeight="SemiBold" />
                  <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding PartitionSettings.MinPartitionVRAM}" />
                  <TextBox Grid.Row="1" Grid.Column="2" Text="{Binding PartitionSettings.OptimalPartitionVRAM}" />
                  <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding PartitionSettings.MaxPartitionVRAM}" />

                  <TextBlock Grid.Row="2" Text="Encode" VerticalAlignment="Center" FontWeight="SemiBold" />
                  <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding PartitionSettings.MinPartitionEncode}" />
                  <TextBox Grid.Row="2" Grid.Column="2" Text="{Binding PartitionSettings.OptimalPartitionEncode}" />
                  <TextBox Grid.Row="2" Grid.Column="3" Text="{Binding PartitionSettings.MaxPartitionEncode}" />

                  <TextBlock Grid.Row="3" Text="Decode" VerticalAlignment="Center" FontWeight="SemiBold" />
                  <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding PartitionSettings.MinPartitionDecode}" />
                  <TextBox Grid.Row="3" Grid.Column="2" Text="{Binding PartitionSettings.OptimalPartitionDecode}" />
                  <TextBox Grid.Row="3" Grid.Column="3" Text="{Binding PartitionSettings.MaxPartitionDecode}" />

                  <TextBlock Grid.Row="4" Text="Compute" VerticalAlignment="Center" FontWeight="SemiBold" />
                  <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding PartitionSettings.MinPartitionCompute}" />
                  <TextBox Grid.Row="4" Grid.Column="2" Text="{Binding PartitionSettings.OptimalPartitionCompute}" />
                  <TextBox Grid.Row="4" Grid.Column="3" Text="{Binding PartitionSettings.MaxPartitionCompute}" />
                </Grid>
              </StackPanel>
            </Border>
          </ScrollViewer>
        </TabItem>

        <TabItem>
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,14,0">
              <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                  <TextBlock Text="Paso 5: Aplicar configuracion" Style="{StaticResource SectionTitleStyle}" />
                  <WrapPanel>
                    <CheckBox Content="Crear checkpoint antes de cambiar la VM" IsChecked="{Binding CreateCheckpoint}" />
                  </WrapPanel>
                  <Button Content="Aplicar GPU-P ahora" Command="{Binding ApplyGpuPartitionCommand}" Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Left" />
                  <Button Content="Quitar GPU de la VM" Command="{Binding RemoveGpuPartitionCommand}" HorizontalAlignment="Left" />
                  <TextBlock Text="La app no usa RemoteFX. Usa Add-VMGpuPartitionAdapter, Set-VMGpuPartitionAdapter, Set-VM y Get-VMHostPartitionableGpu cuando estan disponibles."
                             Foreground="{DynamicResource MutedTextBrush}" Margin="0,8,0,0" />
                </StackPanel>
              </Border>

              <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                  <TextBlock Text="Preparar drivers para la VM" Style="{StaticResource SectionTitleStyle}" />
                  <TextBlock Text="Usuario administrador del guest para PowerShell Direct" Style="{StaticResource CaptionStyle}" />
                  <TextBox Text="{Binding GuestUserName, UpdateSourceTrigger=PropertyChanged}" />
                  <TextBlock Text="Contrasena del guest" Style="{StaticResource CaptionStyle}" />
                  <PasswordBox PasswordChanged="GuestPasswordBox_OnPasswordChanged"
                               Background="{DynamicResource PanelAltBrush}"
                               Foreground="{DynamicResource TextBrush}"
                               BorderBrush="{DynamicResource BorderBrush}"
                               Padding="10,7"
                               Margin="0,4,0,10" />
                  <Button Content="Preparar drivers automaticamente" Command="{Binding PrepareDriversCommand}" HorizontalAlignment="Left" />
                  <TextBlock Text="{Binding DriverInstructions}" Foreground="{DynamicResource MutedTextBrush}" Margin="0,8,0,0" />
                </StackPanel>
              </Border>
            </StackPanel>
          </ScrollViewer>
        </TabItem>

        <TabItem>
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,14,0">
              <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                  <TextBlock Text="Paso 6: Validar y arrancar" Style="{StaticResource SectionTitleStyle}" />
                  <WrapPanel>
                    <CheckBox Content="Probar arranque durante la validacion" IsChecked="{Binding TryStartDuringValidation}" />
                  </WrapPanel>
                  <WrapPanel>
                    <Button Content="Validar configuracion" Command="{Binding ValidateCommand}" Style="{StaticResource PrimaryButtonStyle}" />
                    <Button Content="Iniciar VM" Command="{Binding StartVmCommand}" />
                    <Button Content="Abrir Hyper-V Manager" Command="{Binding OpenHyperVManagerCommand}" />
                    <Button Content="Abrir VMConnect" Command="{Binding OpenVmConnectCommand}" />
                  </WrapPanel>
                </StackPanel>
              </Border>

              <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                  <TextBlock Text="Resultados" Style="{StaticResource SectionTitleStyle}" />
                  <ItemsControl ItemsSource="{Binding ValidationResults}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                          <StackPanel>
                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" Foreground="{Binding Severity, Converter={StaticResource SeverityBrushConverter}}" />
                            <TextBlock Text="{Binding Message}" Foreground="{DynamicResource MutedTextBrush}" />
                          </StackPanel>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </Border>
            </StackPanel>
          </ScrollViewer>
        </TabItem>
      </TabControl>

      <Border Grid.Column="2" Style="{StaticResource CardStyle}" Margin="0">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
          <StackPanel>
            <TextBlock Text="Logs en tiempo real" Style="{StaticResource SectionTitleStyle}" />
            <TextBlock Text="Guardados en %ProgramData%\HyperVGpuShareManager\logs" Style="{StaticResource CaptionStyle}" />
          </StackPanel>
          <ListBox Grid.Row="1"
                   ItemsSource="{Binding LogLines}"
                   Background="{DynamicResource PanelAltBrush}"
                   BorderBrush="{DynamicResource BorderBrush}"
                   BorderThickness="1"
                   Margin="0,10,0,0"
                   FontFamily="Consolas"
                   FontSize="11"
                   ScrollViewer.VerticalScrollBarVisibility="Auto" />
        </Grid>
      </Border>
    </Grid>

    <Border Grid.Row="2" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="20,5">
      <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource MutedTextBrush}" />
    </Border>
  </Grid>
</Window>
